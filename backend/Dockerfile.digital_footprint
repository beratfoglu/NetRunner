FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    gcc \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    flask==3.0.0 \
    flask-cors==4.0.0 \
    holehe \
    requests==2.31.0

COPY digital_footprint.py .

EXPOSE 5006

CMD ["python", "digital_footprint.py"]